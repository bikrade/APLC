# OpenAI Configuration
# Copy this file to .env and fill in your values.

OPENAI_API_KEY=sk-YOUR-API-KEY
# Optional — defaults to gpt-4o-mini if omitted
OPENAI_MODEL=gpt-4o-mini
# Optional — reading story generation falls back if OpenAI takes longer than this
READING_AI_TIMEOUT_MS=8000
GOOGLE_CLIENT_ID=
AUTH_ALLOWED_EMAIL=
AUTH_SESSION_SECRET=
# Optional: reserved ngrok domain for a stable public URL
NGROK_DOMAIN=
