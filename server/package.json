{
  "name": "server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist test/*.js test/*.js.map test/*.d.ts test/*.d.ts.map vitest.config.js vitest.config.js.map vitest.config.d.ts vitest.config.d.ts.map",
    "dev": "tsx src/index.ts",
    "dev:local": "tsx src/index.ts > ../data/server.log 2>&1",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:local": "node dist/index.js > ../data/server.log 2>&1",
    "lint:eslint": "eslint src test vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint:test": "eslint test vitest.config.ts && npm run typecheck:test",
    "lint": "npm run lint:eslint && npm run typecheck && npm run typecheck:test",
    "pretest": "npm run lint:test",
    "test": "npm run clean && vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "applicationinsights": "^3.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.3",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  }
}
